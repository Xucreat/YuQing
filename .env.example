# ===== 数据库 =====
# 容器内 backend 连接 postgres 服务名使用下方值
DATABASE_URL=postgresql+psycopg://opinion_user:opinion_pass@postgres:5432/opinion_db

# ===== 后端 =====
# 简易 JWT 密钥（MVP 单 admin 用户，禁止 RBAC / refresh token / OAuth）
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== DeepSeek AI =====
# 不配置或调用失败时，AIService 自动降级到 RuleBasedAnalyzer（离线可演示）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== 初始化管理员 =====
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123
